void afiseazaMesajCentral(String txt, uint16_t culoare) {
  tft.fillRect(20, 240, SCR_W - 40, 80, COL_BG); 
  tft.setTextDatum(MC_DATUM);
  tft.setTextColor(culoare, COL_BG); 
  tft.setFont(&fonts::Font4);
  tft.setTextSize(1.3);
