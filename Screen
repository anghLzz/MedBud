}

void afiseazaDateSenzori() {
  tft.fillRect(0, 140, SCR_W, 80, COL_BG);
  tft.setTextDatum(MC_DATUM);
  if (!dateSensibileVizibile) {
    tft.setTextColor(tft.color565(120, 120, 120), COL_BG);
    tft.setFont(&fonts::Font4);
    tft.setTextSize(1.0);
    tft.drawString("[ Date Protejate - Privacy Mode ]", SCR_W / 2, 180);
    return;
  }
  tft.setTextColor(tft.color565(0, 100, 0), COL_BG);
  tft.setFont(&fonts::Font4);
  tft.setTextSize(1.5);
  char buf[128];
  snprintf(buf, sizeof(buf), "Puls: %.1f | SpO2: %.1f%% | Temp: %.1fC", lastPulse, lastSpO2, lastTemp);
  tft.drawString(buf, SCR_W / 2, 180);
}

void drawButton(int i, bool selected) {
  int btnW = (SCR_W - (BTN_GAP * (BTN_COUNT + 1))) / BTN_COUNT;
  int x = BTN_GAP + i * (btnW + BTN_GAP);
  uint16_t bg = (i == 0) ? tft.color565(180, 0, 0) : COL_BTN_BLUE;
  tft.fillRoundRect(x, BTN_Y, btnW, BTN_H, 12, bg);
  if (selected) {
    tft.drawRoundRect(x, BTN_Y, btnW, BTN_H, 12, TFT_WHITE);
    tft.drawRoundRect(x+1, BTN_Y+1, btnW-2, BTN_H-2, 11, TFT_WHITE);
  }
  tft.setTextColor(COL_TEXT, bg);
  tft.setFont(&fonts::Font4);
  tft.setTextSize(0.9);
  tft.drawString(BTN_LABELS[i], x + btnW / 2, BTN_Y + BTN_H / 2 + 2);
}

void drawMainUI() {
  tft.fillScreen(COL_BG);
  tft.setTextDatum(MC_DATUM); tft.setTextColor(COL_LOGO); tft.setFont(&fonts::Font4); tft.setTextSize(2.5);
  tft.drawString("MedBud", SCR_W / 2, 50);
  afiseazaDateSenzori();
  afiseazaMesajCentral(msgDeLaPi, tft.color565(0, 0, 150));
  for (int i = 0; i < BTN_COUNT; i++) drawButton(i, activeBtn == i);
}

void onMqttMessage(char* topic, byte* payload, unsigned int length) {
  StaticJsonDocument<1024> doc;
  DeserializationError error = deserializeJson(doc, payload, length);
  if (error) return;
  JsonObject data = doc.containsKey("client") ? doc["client"] : (doc.containsKey("shared") ? doc["shared"] : doc.as<JsonObject>());
  float nP = data.containsKey("pulse") ? data["pulse"].as<float>() : lastPulse;
  float nO = data.containsKey("oxygen") ? data["oxygen"].as<float>() : lastSpO2;
  float nT = data.containsKey("temperature") ? data["temperature"].as<float>() : lastTemp;

  if (nP == lastPulse && nO == lastSpO2 && nT == lastTemp) {
    dateSensibileVizibile = false;
  } else {
    lastPulse = nP; lastSpO2 = nO; lastTemp = nT;
    dateSensibileVizibile = true;
  }
  if (data.containsKey("comanda")) {
    String newMsg = data["comanda"].as<String>();
    if (newMsg != lastReceivedPiMsg) {
      msgDeLaPi = newMsg;
      lastReceivedPiMsg = newMsg;
      if(!inEasterEgg) afiseazaMesajCentral(msgDeLaPi, tft.color565(0, 0, 150));
    }
  }
  if (!inEasterEgg) afiseazaDateSenzori();
}

void requestAttributes() {
  requestId++;
  String topic = "v1/devices/me/attributes/request/" + String(requestId);
  String payload = "{\"clientKeys\":\"pulse,oxygen,temperature,comanda\", \"sharedKeys\":\"comanda\"}";
  client.publish(topic.c_str(), payload.c_str());
}

