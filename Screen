  }
}

void loopEasterEgg() {
  lgfx::touch_point_t tp;
  bool isTouched = tft.getTouch(&tp);
  if (waitForRelease) {
    if (!isTouched) {
      waitForRelease = false;
      touching = false;
    }
    return; 
  }
  if (isTouched) {
    if (!touching) {
      touching = true;
      btnPressStartTime = millis();
      joacaPacanele(); 
    } else {
      if (millis() - btnPressStartTime > 3000) {
        inEasterEgg = false;
        touching = false;
        drawMainUI();
      }
    }
  } else {
    touching = false;
  }
}

void setup() {
  Serial.begin(115200);
  tft.init();
  tft.setBrightness(200);
  initColors();
  pinMode(PIN_BUTON_PANICA, INPUT_PULLUP);
  drawMainUI();
  WiFi.begin(ssid, password);
  client.setServer(mqtt_server, 1883);
  client.setCallback(onMqttMessage);
  client.setBufferSize(1024);
}

void loop() {
  unsigned long now = millis();
  if (WiFi.status() == WL_CONNECTED) {
    if (!client.connected()) {
      if (now - lastReconnectAttempt > 5000) {
        lastReconnectAttempt = now;
        if (client.connect("Waveshare_MedBud", token, "")) {
          client.subscribe("v1/devices/me/attributes/response/+");
          client.subscribe("v1/devices/me/attributes"); 
          requestAttributes();
        }
      }
    } else {
      client.loop();
      if (now - lastPollTime > 10000) { 
        lastPollTime = now; 
        requestAttributes();
      }
    }
  }

  if (digitalRead(PIN_BUTON_PANICA) == LOW) {
    delay(50); 
    if (digitalRead(PIN_BUTON_PANICA) == LOW) {
      if (activeBtn != 0) {
        if (activeBtn != -1) drawButton(activeBtn, false);
        activeBtn = 0; 
        drawButton(0, true);
        afiseazaMesajCentral(BTN_MESSAGES[0], tft.color565(200, 0, 0));
      }
      while(digitalRead(PIN_BUTON_PANICA) == LOW) { delay(10); }
    }
  }

  if (inEasterEgg) {
    loopEasterEgg();
    return;
  }

  lgfx::touch_point_t tp;
  if (tft.getTouch(&tp)) {
    if (!touching) {
      int btnW = (SCR_W - (BTN_GAP * (BTN_COUNT + 1))) / BTN_COUNT;
      for (int i = 0; i < BTN_COUNT; i++) {
        int x = BTN_GAP + i * (btnW + BTN_GAP);
        if (tp.x >= x && tp.x <= x + btnW && tp.y >= BTN_Y && tp.y <= BTN_Y + BTN_H) {
          if (activeBtn != -1) drawButton(activeBtn, false);
          activeBtn = i;
          drawButton(i, true);
          uint16_t msgColor = (i == 0) ? tft.color565(200, 0, 0) : tft.color565(0, 0, 120);
          afiseazaMesajCentral(BTN_MESSAGES[i], msgColor);
          currentlyPressedBtn = i;
          btnPressStartTime = millis();
          break;
        }
      }
      touching = true;
    } else {
      if (currentlyPressedBtn == 1) { 
        if (millis() - btnPressStartTime >= 3000) {
          inEasterEgg = true;
          waitForRelease = true; 
          initEasterEgg();
          currentlyPressedBtn = -1;
        }
      }
    }
  } else {
    touching = false;
    currentlyPressedBtn = -1;
  }
  delay(10);
}
